# RootSeeker V2 Docker 部署环境变量模板
# 复制为 .env 后按需修改：cp .env.docker .env
#
# 快速启动：
#   docker compose up -d --build
#
# 所有服务默认使用 MySQL 持久化（Compose 内 mysql 服务）+ hash embedding
# 回退 SQLite：ROOTSEEKER_STORAGE_BACKEND=sqlite
# 详见 docs/storage-mysql.md / docs/storage-sqlite.md

# ===========================
# 核心配置
# ===========================

# 存储后端：memory | sqlite | mysql（Docker 推荐 mysql）
ROOTSEEKER_STORAGE_BACKEND=mysql
ROOTSEEKER_SQLITE_DB_PATH=/app/data/rootseeker.db

# Enable mysql compose profile when backend=mysql (start.sh / Makefile sync this)
COMPOSE_PROFILES=mysql

# MySQL（与 compose 服务名 mysql 对齐；不对外 publish 端口）
# 应用与 mysql 容器共用 ROOTSEEKER_MYSQL_*；不要再单独维护一套 MYSQL_USER/PASSWORD
ROOTSEEKER_MYSQL_HOST=mysql
ROOTSEEKER_MYSQL_PORT=3306
ROOTSEEKER_MYSQL_USER=rootseeker
ROOTSEEKER_MYSQL_PASSWORD=rootseeker
ROOTSEEKER_MYSQL_DATABASE=rootseeker
MYSQL_ROOT_PASSWORD=rootseeker_root

# 注意：若本机已有旧 .env 且 STORAGE_BACKEND=sqlite，会覆盖 Compose 默认 mysql
#   - Docker 全栈：mysql + COMPOSE_PROFILES=mysql
#   - 非 Docker / hybrid：sqlite（见 start-local.ps1；可用 -Mysql 切换）
#   - sqlite 时请设 COMPOSE_PROFILES= 空，mysql 容器不会启动

# 子存储：auto 跟随 STORAGE_BACKEND；也可强制 file/sqlite/mysql
ROOTSEEKER_ADMIN_STORE=auto
ROOTSEEKER_CRON_STATE_STORE=auto
ROOTSEEKER_ERROR_HISTORY_STORE=auto

# 内部适配器：composite（SLS/Jaeger/Zoekt 组合），http（外部服务）
ROOTSEEKER_INTERNAL_ADAPTER_KIND=composite

# 容器访问 GitHub 等外网（可选；仅在本机已运行代理时取消注释）
# Windows Docker Desktop 示例（本机代理监听 10808）：
# HTTP_PROXY=http://host.docker.internal:10808
# HTTPS_PROXY=http://host.docker.internal:10808
# NO_PROXY=localhost,127.0.0.1,api,admin,mysql,zoekt,qdrant,gitnexus,host.docker.internal

# ===========================
# AI / LLM 配置（可选）
# ===========================
# 配置后可启用 AI 报告增强和 Agent 工具规划
# 支持任何 OpenAI 兼容端点（DeepSeek、通义千问、Ollama、小米 MiMo 等）
# 小米 MiMo 按量：https://api.xiaomimimo.com/v1
# 小米 MiMo Token Plan（tp- 密钥）：https://token-plan-cn.xiaomimimo.com/v1

ROOTSEEKER_LLM_ENABLED=true
ROOTSEEKER_LLM_BASE_URL=
ROOTSEEKER_LLM_API_KEY=
ROOTSEEKER_LLM_MODEL=
ROOTSEEKER_DEFAULT_AI_PROVIDER=
ROOTSEEKER_DEFAULT_AI_MODEL=

# ===========================
# Embedding 配置
# ===========================
# hash = 本地确定性向量（零依赖），openai_compatible = 需配置 LLM 端点
ROOTSEEKER_EMBEDDING_PROVIDER=hash
ROOTSEEKER_EMBEDDING_DIMENSION=384

# ===========================
# 云效 Codeup Git 克隆（HTTPS）
# ===========================
# Codeup → 个人设置 → HTTPS 密码 → 「克隆账号」（不是 organizationId）
# 配置后 Docker 同步私有仓库时自动注入凭据；也可在 Admin 远端源里单独填写
ROOTSEEKER_CODEUP_GIT_USERNAME=

# ===========================
# 端口映射
# ===========================

API_PORT=8000
ADMIN_PORT=8010
ZOEKT_PORT=6070
ZOEKT_INDEX_PORT=6071
QDRANT_PORT=6333
GITNEXUS_PORT=7474

# ===========================
# 代码索引三层（Compose 默认栈内建）
# ===========================
# Zoekt 词法 / Qdrant 语义 / GitNexus 知识图谱
# 端点由 docker-compose 注入，一般无需改：
#   ROOTSEEKER_ZOEKT_ENDPOINT=http://zoekt:6070
#   ROOTSEEKER_QDRANT_ENDPOINT=http://qdrant:6333
#   ROOTSEEKER_GITNEXUS_ENDPOINT=http://gitnexus:7474
ROOTSEEKER_REPO_ENABLE_ZOEKT=true
ROOTSEEKER_REPO_ENABLE_QDRANT=true
ROOTSEEKER_REPO_ENABLE_GITNEXUS=true

# ===========================
# Qdrant 向量库
# ===========================

ROOTSEEKER_QDRANT_COLLECTION_NAME=code_chunks
ROOTSEEKER_QDRANT_API_KEY=

# ===========================
# 阿里云 SLS（可选，生产环境需要）
# ===========================

SLS_ACCESS_KEY_ID=
SLS_ACCESS_KEY_SECRET=
SLS_ENDPOINT=
SLS_PROJECT=
SLS_LOGSTORE=

# ===========================
# Jaeger Trace（可选）
# ===========================

JAEGER_ENDPOINT=

# ===========================
# 通知通道（可选）
# ===========================
# 至少配置一个通知 URL 才能发送排查结果

ROOTSEEKER_NOTIFY_DEFAULT_URL=
# ROOTSEEKER_NOTIFY_WEBHOOK_URL=
# ROOTSEEKER_NOTIFY_FEISHU_URL=
# ROOTSEEKER_NOTIFY_DINGTALK_URL=
# ROOTSEEKER_NOTIFY_WECHAT_WORK_URL=
