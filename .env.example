# RootSeeker V2 Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Internal Adapter Configuration
# ===========================================

# Adapter kind: "composite" (default, SLS/Jaeger/Zoekt + RepoSyncService), or "http"
ROOTSEEKER_INTERNAL_ADAPTER_KIND=composite

# Webhook URLs for Composite notify.send (at least one must be set to send externally)
ROOTSEEKER_NOTIFY_DEFAULT_URL=
# ROOTSEEKER_NOTIFY_* (optional; override per channel)
# ROOTSEEKER_NOTIFY_WEBHOOK_URL=
# ROOTSEEKER_NOTIFY_FEISHU_URL=
# ROOTSEEKER_NOTIFY_WECHAT_WORK_URL=
ROOTSEEKER_INTERNAL_HTTP_BASE_URL=http://internal:9000
ROOTSEEKER_INTERNAL_HTTP_TIMEOUT_SECONDS=5

# ===========================================
# Alibaba Cloud SLS (Log Service)
# ===========================================

SLS_ACCESS_KEY_ID=
SLS_ACCESS_KEY_SECRET=
SLS_ENDPOINT=cn-hangzhou.log.aliyuncs.com
SLS_PROJECT=
SLS_LOGSTORE=

# ===========================================
# Jaeger (Distributed Tracing)
# ===========================================

JAEGER_ENDPOINT=
JAEGER_TIMEOUT_SECONDS=10

# Zoekt / Qdrant — 与姊妹项目 root_seek/config.yaml 对齐：
#   zoekt.api_base_url -> ZOEKT_ENDPOINT 或 ROOTSEEKER_ZOEKT_ENDPOINT
#   qdrant.url -> QDRANT_ENDPOINT 或 ROOTSEEKER_QDRANT_ENDPOINT
#   qdrant.collection -> QDRANT_COLLECTION_NAME 或 ROOTSEEKER_QDRANT_COLLECTION_NAME
#   qdrant.api_key -> QDRANT_API_KEY 或 ROOTSEEKER_QDRANT_API_KEY（云实例需要）
ZOEKT_ENDPOINT=http://127.0.0.1:6070
ROOTSEEKER_ZOEKT_ENDPOINT=http://127.0.0.1:6070
# Remote index HTTP inside Zoekt container (preferred over host zoekt-index binary)
ROOTSEEKER_ZOEKT_INDEX_ENDPOINT=http://127.0.0.1:6071
# Host clone dir -> container mount (hybrid: <abs>/repos:/repos ; docker: /data/repos:/repos)
# ROOTSEEKER_ZOEKT_PATH_MAP=E:/CodeProjects/root-seeker-v2/repos:/repos
ZOEKT_TIMEOUT_SECONDS=30
ROOTSEEKER_ZOEKT_TIMEOUT_SECONDS=30
ROOTSEEKER_ZOEKT_INDEX_TIMEOUT_SECONDS=600
ROOTSEEKER_ZOEKT_INDEX_DIR=data/zoekt/index
# Optional explicit binary locations for no-Docker local startup/indexing
# ROOTSEEKER_ZOEKT_WEBSERVER=/absolute/path/to/zoekt-webserver
# ROOTSEEKER_ZOEKT_INDEX_BINARY=/absolute/path/to/zoekt-index

QDRANT_ENDPOINT=http://127.0.0.1:6333
ROOTSEEKER_QDRANT_ENDPOINT=http://127.0.0.1:6333
QDRANT_TIMEOUT_SECONDS=30
ROOTSEEKER_QDRANT_TIMEOUT_SECONDS=30
QDRANT_COLLECTION_NAME=code_chunks
ROOTSEEKER_QDRANT_COLLECTION_NAME=code_chunks
QDRANT_API_KEY=
ROOTSEEKER_QDRANT_API_KEY=
# Optional explicit Qdrant binary for no-Docker startup
# ROOTSEEKER_QDRANT_BINARY=/absolute/path/to/qdrant

# Embeddings for Qdrant semantic code search.
# hash = deterministic local vectors, no external service required.
ROOTSEEKER_EMBEDDING_PROVIDER=hash
ROOTSEEKER_EMBEDDING_DIMENSION=384
# For OpenAI-compatible HTTP embeddings:
# ROOTSEEKER_EMBEDDING_PROVIDER=openai_compatible
# ROOTSEEKER_EMBEDDING_BASE_URL=https://api.openai.com/v1
# ROOTSEEKER_EMBEDDING_API_KEY=
# ROOTSEEKER_EMBEDDING_MODEL=text-embedding-3-small
# ROOTSEEKER_EMBEDDING_TIMEOUT_SECONDS=30

# ===========================================
# Repository Sync
# ===========================================

# Base path for cloning repositories
ROOTSEEKER_REPO_BASE_PATH=repos
ROOTSEEKER_REPO_ENABLE_ZOEKT=true
ROOTSEEKER_REPO_ENABLE_QDRANT=true

# ===========================================
# Channel Routing (Notification)
# ===========================================

# Feishu webhook
FEISHU_WEBHOOK_URL=

# DingTalk webhook
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# WeChat Work webhook
WECHAT_WORK_WEBHOOK_URL=

# Slack webhook
SLACK_WEBHOOK_URL=

# Discord webhook
DISCORD_WEBHOOK_URL=

# ===========================================
# API Server
# ===========================================

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Standalone Admin console
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8010

# ===========================================
# Worker Configuration
# ===========================================

WORKER_INTERVAL_SECONDS=5
WORKER_MAX_EMPTY_POLLS=10
WORKER_MAX_RUNS=100

# ===========================================
# Scheduler Configuration
# ===========================================

SCHEDULER_INTERVAL_SECONDS=60
SCHEDULER_MAX_RUNS=0
SCHEDULER_RETRIES=2
SCHEDULER_RETRY_DELAY_SECONDS=5

# ===========================================
# Storage
# ===========================================
# memory | sqlite | mysql
# Non-Docker local default: sqlite. Docker (.env.docker): mysql.
# See docs/storage-mysql.md / docs/storage-sqlite.md
ROOTSEEKER_STORAGE_BACKEND=sqlite
ROOTSEEKER_SQLITE_DB_PATH=data/rootseeker.db
# ROOTSEEKER_MYSQL_HOST=127.0.0.1
# ROOTSEEKER_MYSQL_PORT=3306
# ROOTSEEKER_MYSQL_USER=rootseeker
# ROOTSEEKER_MYSQL_PASSWORD=rootseeker
# ROOTSEEKER_MYSQL_DATABASE=rootseeker
# ROOTSEEKER_MYSQL_POOL_SIZE=8
# ROOTSEEKER_ADMIN_STORE=auto
# ROOTSEEKER_CRON_STATE_STORE=auto
# ROOTSEEKER_ERROR_HISTORY_STORE=auto

# ===========================================
# Observability
# ===========================================

LOG_LEVEL=INFO
LOG_FORMAT=json