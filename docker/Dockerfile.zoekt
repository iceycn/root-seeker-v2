# Zoekt - uses pre-downloaded static binaries (see prepare-zoekt.ps1 / prepare-zoekt.sh)
# Build context: ./docker
FROM alpine:3.19

COPY bin/zoekt-webserver /usr/local/bin/zoekt-webserver
COPY bin/zoekt-index /usr/local/bin/zoekt-index
RUN chmod +x /usr/local/bin/zoekt-webserver /usr/local/bin/zoekt-index && \
    mkdir -p /data/index

EXPOSE 6070
CMD ["zoekt-webserver", "-index", "/data/index", "-listen", ":6070", "-rpc"]
